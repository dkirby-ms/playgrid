{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@eschaton/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__", "src/**/__tests__/**/*"],
  "references": [
    { "path": "../shared" }
  ]
}
