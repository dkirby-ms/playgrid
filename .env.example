# Local development database (used by the server dev script when copied to .env)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/playgrid

# Comma-separated list of game IDs to disable (e.g., risk,dominos)
# In deployed environments, this is set via GitHub Actions environment variables
# (vars.DISABLED_GAMES) — configure it in the GitHub UI per environment.
# DISABLED_GAMES=risk
